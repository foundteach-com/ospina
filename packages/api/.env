# API Configuration
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://postgres:LUobjhbzcLnDeHnONoLdkRbAQLhiXAVm@turntable.proxy.rlwy.net:57784/railway"

# Storage local (Railway Volume)
# En Railway: montar el volumen en /app/uploads y configurar UPLOAD_DIR=/app/uploads
# En local: se usará ./uploads en el directorio actual del proceso
UPLOAD_DIR=./uploads

# URL pública de la API (para generar URLs de archivos)
# En producción: cambia esto por la URL real de tu API en Railway
# Ejemplo: https://api.ospinacomercializadoraysuministros.com
PUBLIC_API_URL=https://api.ospinacomercializadoraysuministros.com
